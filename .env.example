# Copy to .env and fill in values

# Gemini API key for embeddings (semantic search)
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# Brain database connection
BRAIN_DB_HOST=127.0.0.1
BRAIN_DB_PORT=5432
BRAIN_DB_USER=brain
BRAIN_DB_PASSWORD=change-me
BRAIN_DB_NAME=brain

# MCP server port (only used in SSE mode)
BRAIN_MCP_PORT=8787
