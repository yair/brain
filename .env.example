# Copy to .env and fill in values.

# Gemini API key for embeddings (semantic search)
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# ── Brain database connection ──────────────────────────────────────
# Shared by every role below.
BRAIN_DB_HOST=127.0.0.1
BRAIN_DB_PORT=5432
BRAIN_DB_NAME=brain

# ── Role: brain_cli ────────────────────────────────────────────────
# What the CLI, MCP server, and skill connect as. Required on every
# host that runs any brain client.
BRAIN_CLI_DB_USER=brain_cli
BRAIN_CLI_DB_PASSWORD=change-me-cli

# ── Role: brain_dream ──────────────────────────────────────────────
# What the dreaming daemon connects as. Required only on the admin
# host (where the dreamer runs). Not needed on remote clients.
BRAIN_DREAM_DB_USER=brain_dream
BRAIN_DREAM_DB_PASSWORD=change-me-dream

# ── Role: brain (superuser) ────────────────────────────────────────
# Admin / break-glass / backup scripts. Required only on the admin
# host.
BRAIN_ADMIN_DB_USER=brain
BRAIN_ADMIN_DB_PASSWORD=change-me-admin

# ── MCP server ─────────────────────────────────────────────────────
# Only used when running brain-mcp in SSE mode.
BRAIN_MCP_PORT=8787
