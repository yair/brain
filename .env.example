# Copy to .env and fill in values

# Gemini API key for embeddings
GEMINI_API_KEY=your-gemini-api-key

# Brain database connection (defaults shown)
# On bakkies (localhost): leave defaults
# On zhizi (remote):      set BRAIN_DB_HOST=bakkies-hostname-or-ip
BRAIN_DB_HOST=127.0.0.1
BRAIN_DB_PORT=5433
BRAIN_DB_USER=brain
BRAIN_DB_PASSWORD=brain_local_only
BRAIN_DB_NAME=zeresh_brain

# MCP server port (only used in SSE mode)
BRAIN_MCP_PORT=8787
